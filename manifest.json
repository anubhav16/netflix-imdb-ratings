{
  "manifest_version": 3,
  "name": "Netflix IMDb Ratings",
  "version": "0.1.0",
  "description": "Display IMDb ratings for movies while browsing Netflix",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.netflix.com/*",
    "https://www.imdb.com/*",
    "https://api.imdb.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"]
    }
  ],
  "action": {
    "default_title": "Netflix IMDb Ratings"
  }
}
