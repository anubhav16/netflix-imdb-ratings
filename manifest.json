{
  "manifest_version": 3,
  "name": "Netflix IMDb Ratings",
  "version": "0.2.3",
  "description": "Display IMDb ratings for movies while browsing Netflix",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.netflix.com/*",
    "https://www.omdbapi.com/*",
    "https://netflix-imdb-backend.vercel.app/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["src/analytics.js", "src/content.js"],
      "css": ["src/styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/analytics.js"],
      "matches": ["https://www.netflix.com/*"]
    }
  ],
  "action": {
    "default_title": "Netflix IMDb Ratings"
  }
}
